@model Cinema
<div class="modal-content border">
    <form asp-area="Admin" asp-controller="Cinema" asp-action="Edit" method="post" enctype="multipart/form-data">


        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="modal-header px-x1 bg-light border-bottom-0">
            <h5 class="modal-title">Edit Cinema</h5>
        </div>
        <div class="modal-body p-x1">
            <div class="mb-3">
                <label class="fs-0" for="Name">Name</label>
                <input class="form-control" id="Name" type="text" name="Name" required value="@Model.Name" />
            </div>

            <div class="mb-3">
                <label class="fs-0" for="Description">Description</label>
                <textarea class="form-control" rows="3" name="Description" id="Description">@Model.Description</textarea>
            </div>

            <div class="mb-3">
                <label class="fs-0">Image</label>
                <div class="mt-1 mb-2">
                    <img id="previewImg" src="~/images/cinema_images/@Model.Img" alt="Cinema Image"
                         style="max-width: 200px; max-height: 200px; border-radius: 8px;" />
                </div>
                <input type="file" class="form-control" name="ImageFile" accept="image/*"
                       onchange="previewImage(event)" />
            </div>

            <div class="mb-3">
                <label class="fs-0" for="Address">Address</label>
                <input class="form-control" id="Address" type="text" name="Address" required value="@Model.Address" />
            </div>



            <div class="mb-3">
                <label class="fs-0" for="Status">Status</label>
                <select class="form-select" id="Status" name="Status">
                    @if (Model.Status)
                    {
                        <option value="true" selected>Active</option>
                        <option value="false">InActive</option>
                    }
                    else
                    {
                        <option value="true">Active</option>
                        <option value="false" selected>InActive</option>
                    }
                </select>
            </div>
        </div>
        <div class="modal-footer d-flex justify-content-end align-items-center bg-light border-0">
            <button class="btn btn-primary px-4" type="submit">Save</button>
        </div>
    </form>
</div>

<script>
    function previewImage(event) {
        var file = event.target.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('previewImg').src = e.target.result;
            }
            reader.readAsDataURL(file);
        }
    }
</script>
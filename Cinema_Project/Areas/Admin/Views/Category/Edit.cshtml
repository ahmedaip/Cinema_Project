@model Category
<div class="modal-content border">
    <form method="post">
        <div class="modal-header px-x1 bg-light border-bottom-0">
            <h5 class="modal-title">Edit Category</h5>
            @* <button class="btn-close me-n1" type="button" data-bs-dismiss="modal" aria-label="Close"></button> *@
        </div>
        <div class="modal-body p-x1">
            <div class="mb-3">
                <label class="fs-0" for="Name">Name</label>
                <input class="form-control" id="Name" type="text" name="Name" required="required" value="@Model.Name" />
            </div>

            <div class="mb-3">
                <label class="fs-0" for="Description">Description</label>
                <textarea class="form-control" rows="3" name="Description" id="Description">@Model.Description</textarea>
            </div>
            <div class="mb-3">
                <label class="fs-0" for="Status">Status</label>
                <select class="form-select" id="Status" name="Status">
                    @if (Model.Status)
                    {
                        <option value="true" selected="selected">Active</option>
                        <option value="false">InActive</option>

                    }
                    else
                    {
                        <option value="true">Active</option>
                        <option value="false" selected>InActive</option>
                    }
                </select>
            </div>
        </div>
        <div class="modal-footer d-flex justify-content-end align-items-center bg-light border-0">
            <button class="btn btn-primary px-4" type="submit">Save</button>
        </div>
    </form>
</div>